{
  "name": "@smartdevutils/browser",
  "version": "1.0.0",
  "description": "Browser-only utilities — QR codes, clipboard, file handling, accessibility, color blindness simulation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":                 { "import": "./dist/index.js",            "require": "./dist/index.cjs",            "types": "./dist/index.d.ts" },
    "./qrcode":          { "import": "./dist/qrcode.js",           "require": "./dist/qrcode.cjs",           "types": "./dist/qrcode.d.ts" },
    "./clipboard":       { "import": "./dist/clipboard.js",        "require": "./dist/clipboard.cjs",        "types": "./dist/clipboard.d.ts" },
    "./color-blindness": { "import": "./dist/color-blindness.js",  "require": "./dist/color-blindness.cjs",  "types": "./dist/color-blindness.d.ts" },
    "./file":            { "import": "./dist/file.js",             "require": "./dist/file.cjs",             "types": "./dist/file.d.ts" },
    "./accessibility":   { "import": "./dist/accessibility.js",    "require": "./dist/accessibility.cjs",    "types": "./dist/accessibility.d.ts" },
    "./user-agent":      { "import": "./dist/user-agent.js",       "require": "./dist/user-agent.cjs",       "types": "./dist/user-agent.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@smartdevutils/core": "workspace:*",
    "axe-core": "^4.9.0",
    "dompurify": "^3.1.0",
    "qrcode": "^1.5.4",
    "ua-parser-js": "^1.0.40"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["smartdevutils", "browser", "qrcode", "accessibility", "clipboard"],
  "author": "ArchitonixLabs",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/ArchitonixLabs/smartdevutils-packages" }
}
