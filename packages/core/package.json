{
  "name": "@smartdevutils/core",
  "version": "1.0.0",
  "description": "Pure TypeScript utility functions for SmartDevUtils tools — hashing, encoding, formatting, generation, text, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./encoding": {
      "import": "./dist/encoding.js",
      "require": "./dist/encoding.cjs",
      "types": "./dist/encoding.d.ts"
    },
    "./formatting": {
      "import": "./dist/formatting.js",
      "require": "./dist/formatting.cjs",
      "types": "./dist/formatting.d.ts"
    },
    "./hashing": {
      "import": "./dist/hashing.js",
      "require": "./dist/hashing.cjs",
      "types": "./dist/hashing.d.ts"
    },
    "./generation": {
      "import": "./dist/generation.js",
      "require": "./dist/generation.cjs",
      "types": "./dist/generation.d.ts"
    },
    "./text": {
      "import": "./dist/text.js",
      "require": "./dist/text.cjs",
      "types": "./dist/text.d.ts"
    },
    "./formats": {
      "import": "./dist/formats.js",
      "require": "./dist/formats.cjs",
      "types": "./dist/formats.d.ts"
    },
    "./jwt": {
      "import": "./dist/jwt.js",
      "require": "./dist/jwt.cjs",
      "types": "./dist/jwt.d.ts"
    },
    "./dba": {
      "import": "./dist/dba.js",
      "require": "./dist/dba.cjs",
      "types": "./dist/dba.d.ts"
    },
    "./devops": {
      "import": "./dist/devops.js",
      "require": "./dist/devops.cjs",
      "types": "./dist/devops.d.ts"
    },
    "./aiml": {
      "import": "./dist/aiml.js",
      "require": "./dist/aiml.cjs",
      "types": "./dist/aiml.d.ts"
    },
    "./security": {
      "import": "./dist/security-extra.js",
      "require": "./dist/security-extra.cjs",
      "types": "./dist/security-extra.d.ts"
    },
    "./database": {
      "import": "./dist/database.js",
      "require": "./dist/database.cjs",
      "types": "./dist/database.d.ts"
    },
    "./devops-tools": {
      "import": "./dist/devops-tools.js",
      "require": "./dist/devops-tools.cjs",
      "types": "./dist/devops-tools.d.ts"
    },
    "./aiml-tools": {
      "import": "./dist/aiml-tools.js",
      "require": "./dist/aiml-tools.cjs",
      "types": "./dist/aiml-tools.d.ts"
    },
    "./planning": {
      "import": "./dist/planning.js",
      "require": "./dist/planning.cjs",
      "types": "./dist/planning.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "crypto-js": "^4.2.0",
    "eff-diceware-passphrase": "^3.0.0",
    "fast-xml-parser": "^5.8.0",
    "generate-schema": "^2.6.0",
    "he": "^1.2.0",
    "js-beautify": "^1.15.0",
    "js-yaml": "^4.1.1",
    "json-to-ts": "^2.1.0",
    "slugify": "^1.6.9",
    "smol-toml": "^1.6.1",
    "sql-formatter": "^15.8.0",
    "terser": "^5.48.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/he": "^1.2.3",
    "@types/js-beautify": "^1.14.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["smartdevutils", "utilities", "hashing", "encoding", "formatting", "developer-tools"],
  "author": "ArchitonixLabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArchitonixLabs/smartdevutils-packages"
  }
}
